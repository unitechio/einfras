# EINFRA Backend - Development Environment
# Copy this to .env.dev and fill in values

# Server
SERVER_PORT=:8080
SERVER_HOST=0.0.0.0
SERVER_MODE=debug

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5433
DB_USER=einfra
DB_PASSWORD=einfra123
DB_NAME=einfra
DB_SSLMODE=disable
DB_AUTO_MIGRATE=true

# Auth
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars!!
JWT_EXPIRATION=3600
REFRESH_TOKEN_EXPIRY=604800

# Encryption (AES-256 key, 32 bytes base64)
ENCRYPTION_KEY=ADAv9As2IZ9XAumcTA8T5C6SwyLbvmWtYLr1w6KKQ4k=
ENCRYPTION_KEY_VERSION=1

# Logging
LOG_LEVEL=debug
LOG_FORMAT=text
LOG_OUTPUT=both
LOG_FILE_PATH=./logs/api.log
LOG_MAX_AGE_DAYS=14
ELASTICSEARCH_ENABLED=false
ELASTICSEARCH_ENDPOINT=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=einfra-api

# MinIO (optional — used for file storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY_ID=minioadmin
MINIO_SECRET_ACCESS_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET_NAME=einfra
