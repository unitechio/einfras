# Required
SERVER_ID=replace-with-server-uuid
AGENT_TOKEN=replace-with-issued-agent-token

# Control plane reachability.
# Prefer routable addresses, never localhost unless the agent runs on the same host as the API.
CONTROL_PLANE_URL=https://control-plane.example.com
# Optional failover list:
# CONTROL_PLANE_URLS=https://control-plane-a.example.com,https://control-plane-b.example.com

# Optional explicit gRPC endpoints. If omitted, the agent derives host:50051 from CONTROL_PLANE_URL(S).
# GRPC_URL=control-plane.example.com:50051
# GRPC_URLS=cp-a.example.com:50051,cp-b.example.com:50051

# Optional config/runtime metadata
AGENT_MODE=auto
AGENT_VERSION=1.0.0
TENANT_ID=default
HEARTBEAT_INTERVAL=15
AGENT_CONNECT_TIMEOUT=10
AGENT_HEALTH_CHECK_TIMEOUT=5
AGENT_HEALTH_CHECK_PATH=/health
AGENT_BACKOFF_INITIAL=2
AGENT_BACKOFF_MAX=60

# Logging
AGENT_LOG_LEVEL=info
AGENT_LOG_FORMAT=json
AGENT_LOG_FILE=/var/log/einfra-agent/agent.log

# Filesystem and execution safety
AGENT_ALLOWED_READ_ROOTS=/etc,/opt,/srv,/var,/home,/root,/tmp
AGENT_ALLOWED_WRITE_ROOTS=/etc,/opt,/srv,/var,/home,/root,/tmp
AGENT_PLUGIN_ROOT=/opt/einfra/plugins
AGENT_MAX_READ_BYTES=2097152
AGENT_STREAM_CHUNK_BYTES=32768
AGENT_MAX_TAIL_LINES=2000

# Optional auto-update manifest endpoint
# AGENT_UPDATE_MANIFEST_URL=https://control-plane.example.com/artifacts/agent/manifest.json
# AGENT_UPDATE_CHECK_INTERVAL=1800
# AGENT_UPDATE_CHANNEL=stable

# Optional tenant-aware policy enforcement inside the agent runtime
# EINFRA_AGENT_TENANT_ALLOWLIST=tenant-a,tenant-b
# EINFRA_AGENT_TENANT_DENYLIST=tenant-x
# EINFRA_AGENT_GROUP_ALLOWLIST=prod,ops
# EINFRA_AGENT_GROUP_DENYLIST=restricted
# EINFRA_AGENT_POLICY_MATRIX={"prod":{"config.write":["admin"],"package.update":["admin"]},"ops":{"plugin.capabilities":["admin","operator"]}}

# Optional config file path for non-env deployments
# EINFRA_AGENT_CONFIG_FILE=/etc/einfra-agent/config.yaml
